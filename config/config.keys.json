    { "name": "TENCENT_CVM_SYSTEM_DISK_TYPE", "owner": "tencent-nodepool", "required": false, "secret": false, "default": "CLOUD_BSSD" },
    { "name": "TENCENT_CVM_SYSTEM_DISK_SIZE_GB", "owner": "tencent-nodepool", "required": false, "secret": false, "default": "50" },
    { "name": "OPL_TKE_INSTANCE_CHARGE_TYPE", "owner": "tencent-nodepool", "required": false, "secret": false, "default": "POSTPAID_BY_HOUR" },
