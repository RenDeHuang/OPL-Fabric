    { "name": "OPL_CODEX_PROVIDER_NAME", "owner": "workspace-codex", "required": false, "secret": false, "default": "gflabtoken" },
    { "name": "CODEX_HOME", "owner": "workspace-codex", "required": false, "secret": false, "default": "/data/codex" }
