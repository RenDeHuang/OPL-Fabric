    { "name": "OPL_STAGING_E2E_ALLOW_LIVE", "owner": "staging-gate", "required": false, "secret": false, "default": "false" },
    { "name": "OPL_TLS_CERT_ID", "owner": "tke-provider", "required": false, "secret": true },
