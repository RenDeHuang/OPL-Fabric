    { "name": "OPL_WORKSPACE_TLS_CERT_ID", "owner": "tke-provider", "required": false, "secret": true },
    { "name": "OPL_CODEX_MODEL", "owner": "workspace-codex", "required": false, "secret": false, "default": "gpt-5.5" },
