{
  "openapi": "3.1.0",
  "info": {
    "title": "OPL Fabric API",
    "version": "0.1.0",
    "license": {
      "name": "Proprietary",
      "url": "https://github.com/RenDeHuang/OPL-Fabric"
    }
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8787"
    }
  ],
  "security": [
    {
      "operatorToken": []
    }
  ],
  "components": {
    "securitySchemes": {
      "operatorToken": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Readiness": {
        "type": "object",
        "required": ["ready", "provider", "missingEnv", "resourceCatalog", "blockers", "repairHints"],
        "properties": {
          "ready": { "type": "boolean" },
          "provider": { "type": "string", "minLength": 1 },
          "missingEnv": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "resourceCatalog": { "$ref": "#/components/schemas/Catalog" },
          "blockers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "repairHints": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      },
      "Catalog": {
        "type": "object",
        "required": ["schemaVersion", "owner", "productPresets", "computeProfiles", "providerInstanceTypes", "capacityPools", "schedulingPolicies", "storageClasses", "workspaceImages", "ingressDomains"],
        "properties": {
          "schemaVersion": { "type": "integer", "minimum": 2 },
          "owner": { "type": "string", "minLength": 1 },
          "productPresets": { "type": "array", "items": { "$ref": "#/components/schemas/ProductPreset" } },
          "computeProfiles": { "type": "array", "items": { "$ref": "#/components/schemas/ComputeProfile" } },
          "providerInstanceTypes": { "type": "array", "items": { "$ref": "#/components/schemas/ProviderInstanceType" } },
          "capacityPools": { "type": "array", "items": { "$ref": "#/components/schemas/CapacityPool" } },
          "schedulingPolicies": { "type": "array", "items": { "$ref": "#/components/schemas/SchedulingPolicy" } },
          "storageClasses": { "type": "array", "items": { "$ref": "#/components/schemas/StorageClass" } },
          "workspaceImages": { "type": "array", "items": { "$ref": "#/components/schemas/WorkspaceImage" } },
          "ingressDomains": { "type": "array", "items": { "$ref": "#/components/schemas/IngressDomain" } }
        }
      },
      "ProductPreset": {
        "type": "object",
        "required": ["id", "name", "accelerator", "defaultCpu", "defaultMemoryGb", "defaultGpu", "defaultDiskGb", "available", "computeProfileId", "storageClassId", "workspaceImageId", "ingressDomainId", "schedulingPolicyId"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "accelerator": { "type": "string", "enum": ["cpu", "gpu"] },
          "defaultCpu": { "type": "integer", "minimum": 1 },
          "defaultMemoryGb": { "type": "integer", "minimum": 1 },
          "defaultGpu": { "type": "integer", "minimum": 0 },
          "defaultDiskGb": { "type": "integer", "minimum": 1 },
          "available": { "type": "boolean" },
          "unavailableReason": { "type": "string" },
          "computeProfileId": { "type": "string", "minLength": 1 },
          "storageClassId": { "type": "string", "minLength": 1 },
          "workspaceImageId": { "type": "string", "minLength": 1 },
          "ingressDomainId": { "type": "string", "minLength": 1 },
          "schedulingPolicyId": { "type": "string", "minLength": 1 }
        }
      },
      "ComputeProfile": {
        "type": "object",
        "required": ["id", "name", "accelerator", "provider", "minCpu", "maxCpu", "minMemoryGb", "maxMemoryGb", "maxGpu", "customShapesAllowed", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "accelerator": { "type": "string", "enum": ["cpu", "gpu"] },
          "provider": { "type": "string", "minLength": 1 },
          "minCpu": { "type": "integer", "minimum": 1 },
          "maxCpu": { "type": "integer", "minimum": 1 },
          "minMemoryGb": { "type": "integer", "minimum": 1 },
          "maxMemoryGb": { "type": "integer", "minimum": 1 },
          "maxGpu": { "type": "integer", "minimum": 0 },
          "customShapesAllowed": { "type": "boolean" },
          "available": { "type": "boolean" },
          "unavailableReason": { "type": "string" }
        }
      },
      "ProviderInstanceType": {
        "type": "object",
        "required": ["id", "provider", "region", "family", "instanceType", "accelerator", "minCpu", "maxCpu", "minMemoryGb", "maxMemoryGb", "maxGpu", "capacityPoolIds", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "region": { "type": "string", "minLength": 1 },
          "zone": { "type": "string" },
          "family": { "type": "string", "minLength": 1 },
          "instanceType": { "type": "string", "minLength": 1 },
          "accelerator": { "type": "string", "enum": ["cpu", "gpu"] },
          "minCpu": { "type": "integer", "minimum": 1 },
          "maxCpu": { "type": "integer", "minimum": 1 },
          "minMemoryGb": { "type": "integer", "minimum": 1 },
          "maxMemoryGb": { "type": "integer", "minimum": 1 },
          "maxGpu": { "type": "integer", "minimum": 0 },
          "capacityPoolIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "available": { "type": "boolean" },
          "priceHint": { "type": "string" }
        }
      },
      "CapacityPool": {
        "type": "object",
        "required": ["id", "provider", "kind", "isolationMode", "region", "computeProfileIds", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["shared", "dedicated_template", "dedicated"] },
          "isolationMode": { "type": "string", "enum": ["shared_pool", "dedicated_nodepool"] },
          "region": { "type": "string", "minLength": 1 },
          "zone": { "type": "string" },
          "providerRef": { "type": "string" },
          "computeProfileIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "available": { "type": "boolean" },
          "unavailableReason": { "type": "string" }
        }
      },
      "SchedulingPolicy": {
        "type": "object",
        "required": ["id", "mode", "capacityPoolKind", "createPoolIfMissing", "rejectIfNoCapacity", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "mode": { "type": "string", "enum": ["shared_pool", "dedicated_nodepool"] },
          "capacityPoolKind": { "type": "string", "enum": ["shared", "dedicated_template", "dedicated"] },
          "createPoolIfMissing": { "type": "boolean" },
          "rejectIfNoCapacity": { "type": "boolean" },
          "description": { "type": "string", "minLength": 1 }
        }
      },
      "StorageClass": {
        "type": "object",
        "required": ["id", "provider", "storageClassName", "accessMode", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "storageClassName": { "type": "string", "minLength": 1 },
          "accessMode": { "type": "string", "minLength": 1 },
          "available": { "type": "boolean" }
        }
      },
      "WorkspaceImage": {
        "type": "object",
        "required": ["id", "image", "port", "persistentMounts", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "image": { "type": "string", "minLength": 1 },
          "port": { "type": "integer", "minimum": 1 },
          "persistentMounts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "available": { "type": "boolean" }
        }
      },
      "IngressDomain": {
        "type": "object",
        "required": ["id", "host", "pathPattern", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "host": { "type": "string", "minLength": 1 },
          "pathPattern": { "type": "string", "minLength": 1 },
          "available": { "type": "boolean" }
        }
      }
    }
  },
  "paths": {
    "/api/fabric/readiness": {
      "get": {
        "operationId": "getFabricReadiness",
        "summary": "Get Fabric readiness",
        "responses": {
          "200": {
            "description": "Fabric readiness",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Readiness" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/fabric/catalog": {
      "get": {
        "operationId": "getFabricCatalog",
        "summary": "Get Fabric resource catalog",
        "responses": {
          "200": {
            "description": "Fabric resource catalog",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Catalog" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  }
}
