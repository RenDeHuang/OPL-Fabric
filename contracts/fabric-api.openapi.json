{
  "openapi": "3.1.0",
  "info": {
    "title": "OPL Fabric API",
    "version": "0.1.0",
    "license": {
      "name": "Proprietary",
      "url": "https://github.com/RenDeHuang/OPL-Fabric"
    }
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8787"
    }
  ],
  "security": [
    {
      "operatorToken": []
    }
  ],
  "components": {
    "securitySchemes": {
      "operatorToken": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Readiness": {
        "type": "object",
        "required": ["ready", "provider", "missingEnv", "resourceCatalog", "blockers", "repairHints"],
        "properties": {
          "ready": { "type": "boolean" },
          "provider": { "type": "string", "minLength": 1 },
          "missingEnv": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "resourceCatalog": { "$ref": "#/components/schemas/Catalog" },
          "blockers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "repairHints": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      },
      "Catalog": {
        "type": "object",
        "required": ["schemaVersion", "owner", "workspacePackages", "computeProfiles", "storageClasses", "workspaceImages", "ingressDomains"],
        "properties": {
          "schemaVersion": { "type": "integer", "minimum": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "workspacePackages": { "type": "array", "items": { "$ref": "#/components/schemas/WorkspacePackage" } },
          "computeProfiles": { "type": "array", "items": { "$ref": "#/components/schemas/ComputeProfile" } },
          "storageClasses": { "type": "array", "items": { "$ref": "#/components/schemas/StorageClass" } },
          "workspaceImages": { "type": "array", "items": { "$ref": "#/components/schemas/WorkspaceImage" } },
          "ingressDomains": { "type": "array", "items": { "$ref": "#/components/schemas/IngressDomain" } }
        }
      },
      "WorkspacePackage": {
        "type": "object",
        "required": ["id", "name", "accelerator", "cpu", "memoryGb", "gpu", "server", "diskGb", "available", "computeProfileId", "storageClassId", "workspaceImageId", "ingressDomainId"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "accelerator": { "type": "string", "enum": ["cpu", "gpu"] },
          "cpu": { "type": "integer", "minimum": 1 },
          "memoryGb": { "type": "integer", "minimum": 1 },
          "gpu": { "type": "integer", "minimum": 0 },
          "server": { "type": "string", "minLength": 1 },
          "diskGb": { "type": "integer", "minimum": 1 },
          "available": { "type": "boolean" },
          "unavailableReason": { "type": "string" },
          "computeProfileId": { "type": "string", "minLength": 1 },
          "storageClassId": { "type": "string", "minLength": 1 },
          "workspaceImageId": { "type": "string", "minLength": 1 },
          "ingressDomainId": { "type": "string", "minLength": 1 }
        }
      },
      "ComputeProfile": {
        "type": "object",
        "required": ["id", "accelerator", "provider", "cpu", "memoryGb", "gpu", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "accelerator": { "type": "string", "enum": ["cpu", "gpu"] },
          "provider": { "type": "string", "minLength": 1 },
          "cpu": { "type": "integer", "minimum": 1 },
          "memoryGb": { "type": "integer", "minimum": 1 },
          "gpu": { "type": "integer", "minimum": 0 },
          "available": { "type": "boolean" }
        }
      },
      "StorageClass": {
        "type": "object",
        "required": ["id", "provider", "storageClassName", "accessMode", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "storageClassName": { "type": "string", "minLength": 1 },
          "accessMode": { "type": "string", "minLength": 1 },
          "available": { "type": "boolean" }
        }
      },
      "WorkspaceImage": {
        "type": "object",
        "required": ["id", "image", "port", "persistentMounts", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "image": { "type": "string", "minLength": 1 },
          "port": { "type": "integer", "minimum": 1 },
          "persistentMounts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "available": { "type": "boolean" }
        }
      },
      "IngressDomain": {
        "type": "object",
        "required": ["id", "host", "pathPattern", "available"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "host": { "type": "string", "minLength": 1 },
          "pathPattern": { "type": "string", "minLength": 1 },
          "available": { "type": "boolean" }
        }
      }
    }
  },
  "paths": {
    "/api/fabric/readiness": {
      "get": {
        "operationId": "getFabricReadiness",
        "summary": "Get Fabric readiness",
        "responses": {
          "200": {
            "description": "Fabric readiness",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Readiness" }
              }
            }
          },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/api/fabric/catalog": {
      "get": {
        "operationId": "getFabricCatalog",
        "summary": "Get Fabric resource catalog",
        "responses": {
          "200": {
            "description": "Fabric resource catalog",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Catalog" }
              }
            }
          },
          "400": { "description": "Bad request" }
        }
      }
    }
  }
}
